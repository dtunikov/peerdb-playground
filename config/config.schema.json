{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "log": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "description": "Log level.",
          "default": "info",
          "enum": ["trace", "debug", "info", "warn", "error", "fatal"]
        }
      }
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "description": "Port to listen on.",
          "default": 8080
        }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "description": "PostgreSQL URL."
        }
      }
    },
    "temporal": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host_port": {
          "type": "string",
          "description": "Temporal server host:port.",
          "default": "localhost:7233"
        },
        "cdc_task_queue": {
          "type": "string",
          "description": "Temporal task queue name for CDC flows.",
          "default": "cdc-flow"
        }
      }
    },
    "cdc": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "flush_interval_ms": {
          "type": "integer",
          "description": "Default CDC flush interval in milliseconds.",
          "default": 1000
        },
        "max_batch_size": {
          "type": "integer",
          "description": "Default maximum CDC batch size (number of records).",
          "default": 10000
        },
        "heartbeat_interval_ms": {
          "type": "integer",
          "description": "Default CDC Temporal heartbeat interval in milliseconds.",
          "default": 15000
        }
      }
    },
    "encryption_key": {
      "type": "string",
      "description": "AES encryption key (16, 24, or 32 bytes hex-encoded) for encrypting peer configs."
    }
  }
}
